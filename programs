<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Programs | Fitness Effort</title>
    <link rel="stylesheet" href="programs.css">
    <link rel="shortcut icon" type="image/x-icon" href="favicon.ico">
</head>
<body>

    <nav class="navbar">
        <div class="logo">Fitnes<span>Effort</span></div>
        <ul class="nav-links">
            <li><a href="index.html">Home</a></li>
            <li><a href="services.html">Services</a></li>
            <li><a href="programs" class="active">Programs</a></li>
        </ul>
    </nav>

    <main class="program-container">
        <header class="program-header">
            <h1>TRAINING <span>PROGRAMS</span></h1>
            <p>Select a track that matches your fitness goals.</p>
        </header>

        <section class="program-grid">
            <div class="program-card">
                <div class="card-image blue-glow">
                    <span class="tag">Strength</span>
                </div>
                <div class="card-body">
                    <h3>Power Effort</h3>
                    <p>Heavy lifting focus. Master the Squat, Bench, and Deadlift with elite coaching.</p>
                    <div class="card-footer">
                        <span>4 Days/Week</span>
                        <a href="#" class="btn-small">Join Track</a>
                    </div>
                </div>
            </div>

            <div class="program-card featured">
                <div class="card-image orange-glow">
                    <span class="tag">Endurance</span>
                </div>
                <div class="card-body">
                    <h3>Metabolic Burn</h3>
                    <p>High-intensity circuit training designed to incinerate fat and boost heart health.</p>
                    <div class="card-footer">
                        <span>5 Days/Week</span>
                        <a href="#" class="btn-small btn-orange">Join Track</a>
                    </div>
                </div>
            </div>

            <div class="program-card">
                <div class="card-image blue-glow">
                    <span class="tag">Flexibility</span>
                </div>
                <div class="card-body">
                    <h3>Mobility Flow</h3>
                    <p>Restore your body. Focus on deep stretching and functional joint mobility.</p>
                    <div class="card-footer">
                        <span>3 Days/Week</span>
                        <a href="#" class="btn-small">Join Track</a>
                    </div>
                </div>
            </div>
        </section>
    </main>

</body>
</html>